# Copy to .env.local and fill in values from Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Live origin (required in production / Vercel; must match Supabase Auth redirect allow list).
NEXT_PUBLIC_SITE_URL=https://pegasuspair.com
# Local-only: use http://localhost:3000 if you are not testing against the live domain.

# Dev: always show survey + allow client-side submit checks. Run supabase/dev_force_survey_open.sql so RLS allows saves.
# Remove for production season dates.
# NEXT_PUBLIC_FORCE_SURVEY_OPEN=true
